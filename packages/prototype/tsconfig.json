{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "module": "esnext",
    "jsx": "react-jsx",
    "isolatedModules": true,
    "paths": {
      "@prototype/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"]
}
