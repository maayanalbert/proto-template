#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/maayanalbert/Documents/proto-template/node_modules/.pnpm/openapi-typescript@7.13.0_typescript@6.0.3/node_modules/openapi-typescript/node_modules:/Users/maayanalbert/Documents/proto-template/node_modules/.pnpm/openapi-typescript@7.13.0_typescript@6.0.3/node_modules:/Users/maayanalbert/Documents/proto-template/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/maayanalbert/Documents/proto-template/node_modules/.pnpm/openapi-typescript@7.13.0_typescript@6.0.3/node_modules/openapi-typescript/node_modules:/Users/maayanalbert/Documents/proto-template/node_modules/.pnpm/openapi-typescript@7.13.0_typescript@6.0.3/node_modules:/Users/maayanalbert/Documents/proto-template/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../openapi-typescript/bin/cli.js" "$@"
else
  exec node  "$basedir/../openapi-typescript/bin/cli.js" "$@"
fi
